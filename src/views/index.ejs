    async function submitAccessDay() {
      const sn = getDeviceSn();
      const zi = parseInt(document.getElementById('adZoneIndex').value);
      const sections = [];
      for (let i = 1; i <= 5; i++) {
        const s = document.getElementById(`adStart${i}`).value;
        const e = document.getElementById(`adEnd${i}`).value;
        if (s && e) sections.push(`${s}~${e}`);
      }
      await apiCall('/api/setAccessDay', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ deviceSn: sn, dayZones: [{ zoneIndex: zi, sections }] }),
      });
      showAlert('Access day saved');
      bootstrap.Modal.getInstance(document.getElementById('accessDayModal')).hide();
    }

