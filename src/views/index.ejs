    // ── Export table to Excel ──
    function exportTable() {
      const table = document.getElementById('empsTable');
      const rows = table.querySelectorAll('tr');
      let csv = '';
      rows.forEach(row => {
        const cols = row.querySelectorAll('th, td');
        const line = Array.from(cols).map(c => `"${c.textContent.trim()}"`).join(',');
        csv += line + '\n';
      });
      const blob = new Blob([csv], { type: 'text/csv' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'staff_list.csv';
      a.click();
    }

    // ── Init flatpickr ──
    document.addEventListener('DOMContentLoaded', () => {
      flatpickr('.timepick', { enableTime: true, noCalendar: true, dateFormat: 'H:i', time_24hr: true });
      flatpickr('.dtpick', { enableTime: true, dateFormat: 'Y-m-d H:i:S', time_24hr: true });
      loadStaff(1);
